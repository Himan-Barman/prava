NODE_ENV=development
HOST=0.0.0.0
PORT=3000

# Local Mongo
MONGODB_URI=mongodb://localhost:27017/prava_chat
MONGODB_DB_NAME=prava_chat
# Atlas example:
# MONGODB_URI=mongodb+srv://srhimanbarman:<db_password>@cluster0.zbmrn7v.mongodb.net/?retryWrites=true&w=majority&appName=Cluster0
# MONGODB_DB_NAME=prava_chat
# If password contains special chars, URL-encode it first.
MONGODB_MAX_POOL_SIZE=30
MONGODB_MIN_POOL_SIZE=2
MONGODB_SERVER_SELECTION_TIMEOUT_MS=5000
MONGODB_CONNECT_RETRIES=3
MONGODB_CONNECT_RETRY_DELAY_MS=1500

# Transactional email (Resend)
# Production: use a verified domain sender in Resend.
RESEND_API_KEY=
EMAIL_FROM="Prava <no-reply@mail.prava.app>"
EMAIL_REPLY_TO=support@prava.app
APP_NAME=Prava
APP_PUBLIC_URL=https://prava.app
OTP_EXPIRES_MINUTES=10

JWT_SECRET=dev_secret
ACCESS_TOKEN_TTL_SECONDS=900
REFRESH_TOKEN_TTL_SECONDS=2592000
BODY_LIMIT_BYTES=1048576
RATE_LIMIT_MAX=200
RATE_LIMIT_WINDOW_MS=60000
CORS_ORIGIN=*

# Optional Redis (rate limit + cache)
REDIS_URL=
REDIS_TLS=false
REDIS_KEY_PREFIX=prava

# Server tuning
CONNECTION_TIMEOUT_MS=10000
KEEP_ALIVE_TIMEOUT_MS=60000
MAX_PARAM_LENGTH=200

# Backpressure protection (optional)
PRESSURE_MAX_EVENT_LOOP_DELAY_MS=
PRESSURE_MAX_HEAP_USED_BYTES=
PRESSURE_MAX_RSS_BYTES=
PRESSURE_RETRY_AFTER_SECONDS=10

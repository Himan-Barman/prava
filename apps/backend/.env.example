NODE_ENV=development
HOST=0.0.0.0
PORT=3000

# PostgreSQL / Supabase
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:5432/prava
# Supabase example:
# DATABASE_URL=postgresql://postgres:<db_password>@db.<project-ref>.supabase.co:5432/postgres
# If password contains special chars, URL-encode it first.
PG_POOL_MAX=20
PG_POOL_IDLE_TIMEOUT_MS=30000
PG_CONNECT_TIMEOUT_MS=10000
PG_STATEMENT_TIMEOUT_MS=30000

# Transactional email (Resend)
# Production: use a verified domain sender in Resend.
RESEND_API_KEY=
EMAIL_FROM="Prava <no-reply@mail.prava.app>"
EMAIL_REPLY_TO=support@prava.app
APP_NAME=Prava
APP_PUBLIC_URL=https://prava.app
OTP_EXPIRES_MINUTES=10
USERNAME_RESERVATION_MINUTES=5

# Use JWT_SECRET for local HS256 tokens, or JWT_PRIVATE_KEY/JWT_PUBLIC_KEY for RS256.
JWT_SECRET=dev_secret
JWT_PRIVATE_KEY=
JWT_PUBLIC_KEY=
ACCESS_TOKEN_TTL_SECONDS=900
REFRESH_TOKEN_TTL_SECONDS=2592000
BODY_LIMIT_BYTES=1048576
RATE_LIMIT_MAX=200
RATE_LIMIT_WINDOW_MS=60000
CORS_ORIGIN=*

# Optional Redis (rate limit + cache)
REDIS_URL=
REDIS_TLS=false
REDIS_KEY_PREFIX=prava

# Feed recommendation tuning (optional)
FEED_CANDIDATE_MULTIPLIER=10
FEED_MAX_AGE_DAYS=21
FEED_SERVED_HISTORY_HOURS=6
FEED_AGGREGATION_INTERVAL_MS=300000
FEED_WEIGHT_RECENCY=0.22
FEED_WEIGHT_AFFINITY=0.18
FEED_WEIGHT_INTEREST=0.18
FEED_WEIGHT_ENGAGEMENT=0.16
FEED_WEIGHT_TREND=0.10
FEED_WEIGHT_SOCIAL_PROOF=0.08
FEED_WEIGHT_QUALITY=0.08
FEED_WEIGHT_EXPLORATION=0.04
FEED_WEIGHT_NEGATIVE_FEEDBACK=0.35
FEED_WEIGHT_REPETITION=0.12
FEED_WEIGHT_SPAM=0.28

# Server tuning
CONNECTION_TIMEOUT_MS=10000
KEEP_ALIVE_TIMEOUT_MS=60000
MAX_PARAM_LENGTH=200

# Backpressure protection (optional)
PRESSURE_MAX_EVENT_LOOP_DELAY_MS=
PRESSURE_MAX_HEAP_USED_BYTES=
PRESSURE_MAX_RSS_BYTES=
PRESSURE_RETRY_AFTER_SECONDS=10
